{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(pandoc:*)",
      "Bash(python:*)",
      "Bash(python3:*)"
    ],
    "deny": [
      "Bash(choco:*)",
      "Bash(winget:*)",
      "Bash(apt-get:*)",
      "Bash(apt:*)",
      "Bash(brew:*)",
      "Bash(npm install -g:*)"
    ]
  }
}
