# Copy this file to .env and fill in real values. Never commit the real .env file.

# Stripe secret key (test mode key looks like sk_test_..., live mode sk_live_...)
# Start with the TEST key until you've verified a full purchase end to end.
STRIPE_SECRET_KEY=

# The live URL where storefront/ is served after GitHub Pages deploys it,
# e.g. https://yourusername.github.io/ai-ebook-company
# Used by scripts/stripe_publish.py to build the post-purchase redirect link.
STOREFRONT_BASE_URL=
