# Copy this file to .env and fill in real values. Never commit the real .env file.

# Paystack secret key (test mode key looks like sk_test_..., live mode sk_live_...)
# Start with the TEST key until you've verified a full purchase end to end.
# Used instead of Stripe because Stripe doesn't support Nigeria for standard
# merchant accounts -- Paystack is Stripe-owned and built for Nigerian businesses.
PAYSTACK_SECRET_KEY=

# The live URL where docs/ is served after GitHub Pages deploys it,
# e.g. https://yourusername.github.io/ai-ebook-company
# Used by scripts/paystack_publish.py to build the post-purchase redirect link.
STOREFRONT_BASE_URL=
