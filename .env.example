# Copy this file to .env and fill in real values. Never commit the real .env file.

# Paystack secret key (test mode key looks like sk_test_..., live mode sk_live_...)
# Start with the TEST key until you've verified a full purchase end to end.
# Used instead of Stripe because Stripe doesn't officially support Nigeria as a
# business's home country -- Paystack is Stripe-owned and built for Nigerian
# businesses, and can accept/settle USD once international payments are enabled.
PAYSTACK_SECRET_KEY=

# Paystack public/publishable key -- not used by the current scripts (they only
# call the server-side API with the secret key), kept here for reference in case
# a future client-side checkout embed needs it.
PAYSTACK_PUBLIC_KEY=

# Currency actually charged at checkout. USD requires "Accept international
# payments" to be enabled on your Paystack account (Preferences tab, after
# business KYC activation -- see README). Until approved, set this to NGN --
# scripts/paystack_publish.py auto-converts the USD price to NGN at a live
# rate. Switch to USD the moment international payments gets approved.
PAYSTACK_CURRENCY=NGN

# The live URL where docs/ is served after GitHub Pages deploys it,
# e.g. https://yourusername.github.io/ai-ebook-company
# Used by scripts/paystack_publish.py to build the post-purchase redirect link.
STOREFRONT_BASE_URL=
